@page "/chat"
@namespace ChatApp.Pages
@using ChatApp.Models
@inherits ChatBase
@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16 pb-8">
    <MudGrid Justify="Justify.Center">
            @* Left Sidebar - Active Users/Rooms *@
            <MudItem xs="12" sm="3" Class="d-none d-sm-block">
                <div class="d-flex flex-column" style="height: 80vh;">
                    
                    @* Global Lobby Button *@
                    <MudButton FullWidth="true" 
                            Variant="@(string.IsNullOrEmpty(SelectedPrivateUser) ? Variant.Filled : Variant.Text)"
                            Color="Color.Primary"
                            StartIcon="@Icons.Material.Filled.Public"
                            OnClick="@SelectGlobalChat"
                            Class="mb-2"
                            Style="border-radius: 12px; min-height: 48px;">
                        Global Lobby
                    </MudButton>

                    @* Scrollable Container *@
                    <MudPaper Elevation="3" Class="pa-4 flex-grow-1" Style="border-radius: 16px; overflow-y: auto;">
                        <MudText Typo="Typo.h6" Class="mb-4">Online (@OnlineUsers.Count)</MudText>
                        
                        <MudList T="UserDto" Dense="true">
                            @foreach (UserDto user in OnlineUsers)
                            {
                                <MudListItem>
                                    <ChildContent>
                                        <div class="d-flex align-center justify-space-between w-100">
                                            @* User Icon and Name *@
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Circle" 
                                                        Size="Size.Small"
                                                        Color="@(user.Username == CurrentUser ? Color.Primary : Color.Success)" 
                                                        Class="mr-3"/>
                                                <MudText Typo="Typo.body2">
                                                    @user.Username @(user.Username == CurrentUser ? "(You)" : "")
                                                </MudText>
                                            </div>

                                            @* The Menu Button *@
                                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" 
                                                    Size="Size.Small" 
                                                    Dense="true"
                                                    FixedPlacement="true"
                                                    AnchorOrigin="Origin.BottomRight"
                                                    TransformOrigin="Origin.TopRight">
                                                <MudMenuItem Icon="@Icons.Material.Filled.Person" 
                                                            OnClick="@(() => ViewProfile(user))">View Profile</MudMenuItem>
                                                @if (user.Username != CurrentUser)
                                                {
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Chat" 
                                                                OnClick="@(() => OpenPrivateChat(user))">Message</MudMenuItem>
                                                }
                                            </MudMenu>
                                        </div>
                                    </ChildContent>
                                </MudListItem>
                            }
                        </MudList>
                    </MudPaper>
                </div>
            </MudItem>
        @* Right Side - Chat Window *@
        <MudItem xs="12" sm="9">
            <MudPaper Elevation="3" Class="d-flex flex-column" Style="height: 80vh; border-radius: 16px; overflow: hidden;">
                
                @* Chat Header *@
                <MudToolBar Dense="true" Class="mud-theme-primary">
                    <MudIcon Icon="@Icons.Material.Filled.ChatBubble" Class="mr-2" />
                    <MudText Typo="Typo.h6">Global Lobby</MudText>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" />
                    @* Added Logout Button *@
                    <MudTooltip Text="Logout">
                        <MudIconButton Icon="@Icons.Material.Filled.Logout" 
                                    Color="Color.Inherit" 
                                    OnClick="@HandleLogout" />
                    </MudTooltip>
                </MudToolBar>

                @* Message List Area *@
                <MudCardContent Style="flex-grow: 1; overflow-y: auto;" Class="pa-4 bg-light" id="chat-container">
                        @if (hasMoreMesssages && _isScrolledToTop)
                        {
                            <div class="d-flex justify-center mb-4">
                                <MudButton Variant="Variant.Text" 
                                            Color="Color.Primary" 
                                            OnClick="@(() => LoadMessagesAsync(false))"
                                            Disabled = "@_isLoadingOlder"
                                            StartIcon="@(_isLoadingOlder ? null : Icons.Material.Filled.History)">
                                        @if(_isLoadingOlder){
                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">Loading...</MudText>
                                        }
                                        else
                                        {
                                            <MudText>View Older Messages</MudText>
                                        }
                                    
                                </MudButton>
                            </div>
                        }
                        @if (Messages == null || !Messages.Any())
                        {
                            <div class="d-flex flex-column align-center justify-center h-100 opacity-50">
                                <MudIcon Icon="@Icons.Material.Filled.Forum" Style="font-size: 4rem;" />
                                <MudText Typo="Typo.body1">No messages yet...</MudText>
                            </div>
                        } else
                        {
                            @foreach (var msg in Messages)
                            {
                                bool isMe = msg.Username == CurrentUser;
                                <div class="d-flex @(isMe ? "justify-end" : "justify-start") mb-4">
                                    <div class="d-flex flex-column @(isMe ? "align-end" : "align-start")" style="max-width: 70%;">
                                        <MudText Typo="Typo.caption" Class="px-2">@msg.Username • @msg.CreatedAt.ToString("HH:mm")</MudText>
                                        <MudPaper Elevation="1" 
                                                Class="@(isMe ? "pa-3 mud-theme-primary" : "pa-3 bg-white")" 
                                                Style="@(isMe ? "border-radius: 15px 15px 0 15px;" : "border-radius: 15px 15px 15px 0;")">
                                            <MudText Typo="Typo.body1" Style="word-wrap: break-word; overflow-wrap: anywhere;" >@msg.Content</MudText>
                                        </MudPaper>
                                    </div>
                                </div>
                            }
                        }

                </MudCardContent>

                @* Sticky Bottom Input *@
                <MudDivider />
                <div class="pa-4 bg-white">
                    <MudTextField @bind-Value="NewMessage"
                                  Placeholder="@(_isSending ? "Sending..." : "Write a message...")"
                                  Variant="Variant.Outlined" 
                                  Adornment="Adornment.End" 
                                  Immediate="true"
                                  AdornmentIcon="@Icons.Material.Filled.Send" 
                                  OnAdornmentClick="SendMessageAsync"
                                  OnkeyDown="@HandleKeyPress"
                                  FullWidth="true"
                                  Margin="Margin.Dense"
                                  AutoGrow 
                                  Lines="1"
                                  MaxLines="5"
                                  KeyDownPreventDefault = "_shouldPreventDefault"
                                  onscroll=""/>
                </div>

            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
<script>
    window.watchChatScrollById = function (id, dotNetHelper) {
        var element = document.getElementById(id);
        if (element) {
            element.addEventListener('scroll', function () {
                var isAtTop = element.scrollTop < 20;
                dotNetHelper.invokeMethodAsync('OnChatScroll', isAtTop);
            });
        }
    };

    window.ScrollToBottom = function (id) {
        var element = document.getElementById(id);
        if (element) {
            element.scrollTo({
                top: element.scrollHeight,
                behavior: 'smooth'
            });
        }
    };
</script>