@page "/login"
@namespace ChatApp.Pages
<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center">Welcome</MudText>
        
        <MudTextField @bind-Value="username" 
                      Label="Username" 
                      Variant="Variant.Outlined" 
                      FullWidth="true" 
                      Class="mb-4" 
                      Immediate = "true"
                      OnkeyDown="@HandleKeyPress"/>

        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   FullWidth="true" 
                   Size="Size.Large"
                   OnClick="@HandleLogin">
            Login
        </MudButton>
    </MudPaper>
</MudContainer>