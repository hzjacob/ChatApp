@page "/"

<PageTitle>Welcome - ChatApp</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center" Style="height: 80vh;">
    
    @* Animated Logo/Icon Section *@
    <div class="welcome-animation">
        <MudIcon Icon="@Icons.Material.Filled.Forum" Color="Color.Primary" Style="font-size: 7rem;" />
    </div>

    <MudText Typo="Typo.h2" Class="mud-text-primary fw-bold mt-7">
        Welcome to ChatApp
    </MudText>
    
    <MudText Typo="Typo.h6" Class="mud-text-secondary mt-2 mb-10" Align="Align.Center">
        Simple. Secure. Instant.
    </MudText>

    <MudButton Variant="Variant.Filled" 
               Color="Color.Primary" 
               Size="Size.Large" 
               Href="/login"
               Style="border-radius: 25px; padding: 12px 40px; font-weight: 700;"
               EndIcon="@Icons.Material.Filled.ArrowForward">
        Get Started
    </MudButton>

</MudContainer>

<style>
    .welcome-animation {
        animation: float 4s ease-in-out infinite;
    }

    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
    }
</style>