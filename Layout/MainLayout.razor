@using ChatApp.Pages
@inject ChatApp.Services.States ChatState
@inherits LayoutComponentBase
@inject NavigationManager Nav
@* Essential providers for styling, dialogs, and notifications *@
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudLink Href="/" Underline="Underline.None" Class="d-flex align-center">
        <img src="images/logo.png" 
             alt="ChatApp Logo" 
             style="height: 85px; width: auto; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1)); transition: transform 0.3s ease;" 
             class="logo-hover" />
        </MudLink>
        <MudSpacer />
        @if (IsChatPage)
        {
        <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <MudMenuItem Icon="@Icons.Material.Filled.Person" Disabled="true">My Profile</MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@(() => ChatState.Logout(null))">Logout</MudMenuItem>
        </MudMenu>
        }
    </MudAppBar>

    @* The sidebar (MudDrawer) is deleted from here *@

    <MudMainContent Class="pt-4 px-2">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    private bool IsChatPage => Nav.Uri.EndsWith("/chat")  || Nav.Uri.Contains("/chat/");

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += (s,e) => StateHasChanged();
    }
    public void Dispose()
    {
        Nav.LocationChanged += (s,e) => StateHasChanged();
    }

}
<style>
    .logo-hover:hover {
        transform: scale(1.08);
    }
</style>    